*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.venv-*/
venv/
env/

# Local runtime
*.log

# Environment/secrets — keep .env.example templates for GitHub
.env
.env.*
!.env.example
!**/.env.example

# OS/editor
.DS_Store
Thumbs.db
.vscode/
