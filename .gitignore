# Generated PHREEQC databases: keep examples/metadata, not user data files
data/databases/generated/*.dat
!data/databases/generated/.gitkeep
!data/databases/generated/example.meta.json

# SQLite PHREEQC catalog cache (regenerated from PHREEQC on startup)
data/catalog.sqlite
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# IPhreeqc scratch dumps written to the working directory on error/dump
error.inp
phreeqc.out
dump.out
error.out
selected.out
phreeqc.log

# Docker/local overrides
docker-data/
docker-compose.override.yml

# Local dev tests (not part of the shipped package)
tests/

# Personal deploy configs (not shipped)
truenas_deploy/
maintainer-notes.md
