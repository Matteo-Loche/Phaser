# PHASER server deployment — copy to .env beside docker-compose.yml (gitignored).
# Tune without rebuilding the image; restart with: docker compose up -d

PHASER_PORT=8765
PHASER_HOST=0.0.0.0

# Set both to the same value on your host (Docker cgroup + worker pool).
PHASER_CPU_LIMIT=8
PHASER_MAX_WORKERS=8
PHASER_MAX_CONCURRENT_JOBS=1
PHASER_MEMORY_LIMIT=8G

PHASER_ADAPTIVE_REFINE_FACTOR=5
PHASER_MAX_ADAPTIVE_POINTS=120000
PHASER_JOB_RESULT_TTL_SEC=3600
PHASER_JOB_QUEUE_TTL_SEC=7200
PHASER_JOB_REAPER_INTERVAL_SEC=60

# Optional: host path for generated .dat persistence (compose volume source)
# PHASER_DATA_DIR=./data/databases/generated
# PHASER_DEFAULT_DB_ID=builtin-phreeqc

# Per-client API rate limits (requests per 60 s window; 0 = unlimited for that bucket)
PHASER_RATE_LIMIT=1
PHASER_RATE_LIMIT_WINDOW_SEC=60
PHASER_RATE_LIMIT_API_PER_MIN=600
PHASER_RATE_LIMIT_COMPUTE_PER_MIN=12
PHASER_RATE_LIMIT_COMPUTE_COOLDOWN_SEC=600
PHASER_RATE_LIMIT_DB_REGISTER_PER_MIN=6
PHASER_RATE_LIMIT_DB_REGISTER_COOLDOWN_SEC=300
PHASER_RATE_LIMIT_PHASES_PER_MIN=60
# Double cooldown after each repeat offense (10 min -> 20 min -> 40 min … cap 1 h)
PHASER_RATE_LIMIT_COOLDOWN_ESCALATE=1
PHASER_RATE_LIMIT_COOLDOWN_MAX_SEC=3600
PHASER_RATE_LIMIT_VIOLATION_RESET_SEC=86400

# Cloudflare Tunnel (never commit a real token)
CLOUDFLARE_TUNNEL_TOKEN=

# Watchtower auto-update check interval in seconds (default 3600 = 1 h)
# WATCHTOWER_INTERVAL=3600
