# PHASER service
PHASER_PORT=8765
PHASER_HOST=0.0.0.0

# Container defaults use the IPhreeqc library and databases built into the image.
PHASER_IPHREEQC_LIB=/usr/local/lib/libiphreeqc.so
PHASER_BUILTIN_DB_DIRS=/opt/phreeqc/database
PHASER_GENERATED_DB_DIR=/app/PHASER/data/databases/generated

# Optional: set a registry id returned by /api/databases.
# PHASER_DEFAULT_DB_ID=builtin-phreeqc

# Cloudflare Tunnel (never commit a real token)
CLOUDFLARE_TUNNEL_TOKEN=
