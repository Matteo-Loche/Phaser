# PHASER server deployment — copy to .env beside docker-compose.yml (gitignored).
# Tune without rebuilding the image; restart with: docker compose up -d

PHASER_PORT=8765
PHASER_HOST=0.0.0.0

# PHASER_CPU_LIMIT: Docker cgroup cap. PHASER_MAX_WORKERS: processes per sweep.
# With MAX_CONCURRENT_JOBS=1, matching CPU_LIMIT and MAX_WORKERS is a good default.
# With multiple concurrent jobs, lower MAX_WORKERS or raise CPU_LIMIT (see README).
PHASER_CPU_LIMIT=8
PHASER_MAX_WORKERS=8
PHASER_MAX_CONCURRENT_JOBS=1
PHASER_MEMORY_LIMIT=8G

PHASER_ADAPTIVE_REFINE_FACTOR=5
PHASER_MAX_ADAPTIVE_POINTS=120000
PHASER_JOB_RESULT_TTL_SEC=3600
PHASER_JOB_QUEUE_TTL_SEC=7200
PHASER_JOB_REAPER_INTERVAL_SEC=60
# Hard kill running jobs after this many seconds (from started_at)
PHASER_JOB_WALL_TIMEOUT_SEC=300

# Optional: host path for generated .dat persistence (compose volume source)
# PHASER_DATA_DIR=./data/databases/generated
# PHASER_DEFAULT_DB_ID=builtin-phreeqc

# Hide builtin databases from the UI (comma-separated stems). Default list is built-in;
# set empty to show all shipped IPhreeqc databases.
PHASER_DISABLED_DB_STEMS=iso,coldchem,frezchem,kinec-v2,kinec-v3,phreeqc-rates,pitzer,sit

# Compute admission: max running+queued jobs; min seconds between compute attempts / IP
PHASER_MAX_QUEUE=20
PHASER_COMPUTE_MIN_INTERVAL_SEC=10

# Per-client API rate limits (requests per 60 s window; 0 = unlimited for that bucket)
# Compute: 4 / min, then 2 h cooldown doubling to 7 d; strikes reset after 30 d
PHASER_RATE_LIMIT=1
PHASER_RATE_LIMIT_WINDOW_SEC=60
PHASER_RATE_LIMIT_API_PER_MIN=600
PHASER_RATE_LIMIT_COMPUTE_PER_MIN=4
PHASER_RATE_LIMIT_COMPUTE_COOLDOWN_SEC=7200
PHASER_RATE_LIMIT_DB_REGISTER_PER_MIN=6
PHASER_RATE_LIMIT_DB_REGISTER_COOLDOWN_SEC=300
PHASER_RATE_LIMIT_PHASES_PER_MIN=60
PHASER_RATE_LIMIT_COOLDOWN_ESCALATE=1
PHASER_RATE_LIMIT_COOLDOWN_MAX_SEC=604800
PHASER_RATE_LIMIT_VIOLATION_RESET_SEC=2592000

# Cloudflare Tunnel (never commit a real token)
CLOUDFLARE_TUNNEL_TOKEN=

# Watchtower auto-update check interval in seconds (default 3600 = 1 h)
# WATCHTOWER_INTERVAL=3600

# About links (Statistics page; defaults to GitHub repo + issues + LICENSE in repo)
# PHASER_REPO_URL=https://github.com/matteo-loche/phaser
# PHASER_ISSUES_URL=https://github.com/matteo-loche/phaser/issues
# PHASER_LICENSE_NAME=AGPL-3.0
# PHASER_LICENSE_URL=https://github.com/matteo-loche/phaser/blob/main/LICENSE.txt
# PHASER_DOI_URL=              # optional override; default is DOI_URL in __version__.py
# PHASER_BUILD_ID=          # set in CI Docker builds; optional locally
